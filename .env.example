# =========================================================
# Servixa AI - Environment Variables (Example)
# Copy this file to `.env` and fill in real values.
# Never commit the actual `.env` file.
# =========================================================

# --- Application ---------------------------------------------------
APP_NAME=Servixa AI
APP_VERSION=0.1.0
HOST=127.0.0.11
PORT=8888
DEBUG=True

# --- Logging ---------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE_PATH=app/storage/logs/servixa.log

# --- Storage -----------------------------------------------------------
STORAGE_PATH=app/storage
UPLOADS_PATH=app/storage/uploads
CROPPED_PATH=app/storage/cropped
ENHANCED_PATH=app/storage/enhanced
CACHE_PATH=app/storage/cache
OUTPUTS_PATH=app/storage/outputs

# --- Pricing Model -------------------------------------------------------
PRICING_MODEL_PATH=app/modules/pricing/models/model.pkl
PRICING_PIPELINE_PATH=app/modules/pricing/models/pipeline.pkl

# --- ID Verification ---------------------------------------------------------
YOLO_MODEL_PATH=app/modules/id_verification/models/yolo_id_detector.pt
YOLO_CONFIDENCE_THRESHOLD=0.5

# --- LLM (Google Gemini) ---------------------------------------------------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash-lite
GEMINI_TEMPERATURE=0.2


# --- LLM (GROQ) ---------------------------------------------------------
GROQ_API_KEY=
REVIEW_MODEL=llama-3.1-8b-instant
REVIEW_TEMPERATURE=0.0
OCR_MODEL=qwen/qwen3.6-27b
OCR_TEMPERATURE=0.0

# --- RAG / Vector Database ---------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_DB_PATH=app/modules/rag_chatbot/vectordb

# --- Future / Reserved ---------------------------------------------------------
# REDIS_URL=
# CORS_ORIGINS=
# API_KEY_HEADER=
# SENTRY_DSN=
